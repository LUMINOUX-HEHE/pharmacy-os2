{
  "name": "pharmacy-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Production-grade SaaS operating system for independent pharmacies in India.",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md,yml,yaml}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "seed": "npm --workspace @pharmacy-os/api run seed",
    "migrate": "npm --workspace @pharmacy-os/api run migrate",
    "clean": "turbo clean && rimraf node_modules"
  },
  "prisma": {
    "seed": "npm --workspace @pharmacy-os/api run seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
