# Core
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
STOREFRONT_URL=http://localhost:5173

# Database and cache
DATABASE_URL=postgresql://pharmacy:pharmacy@postgres:5432/pharmacy_os?schema=public
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=replace-with-a-64-character-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-64-character-refresh-token-secret

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
